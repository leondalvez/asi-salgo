# Copiá este archivo como server/.env en local (no se sube a GitHub).
# En Render: Settings → Environment → Add Environment Variable

# Supabase → Project Settings → Database → Connection string → URI
# Usá "Session pooler" o "Direct connection". Reemplazá [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Orígenes permitidos para POST (CORS). Separá varios con coma si hace falta.
# Por defecto ya incluye https://asi-salgo.onrender.com y localhost:3000.
# ORIGENES_PERMITIDOS=https://asi-salgo.onrender.com,http://localhost:3000
